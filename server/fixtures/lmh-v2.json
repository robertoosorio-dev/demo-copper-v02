    "data": {
      "document": "",
      "model": {
        "name": "LMH Q3 2025 Activation",
        "entities": {
          "tbl_health_events": {
            "type": "Table",
            "name": "HealthUserEvents",
            "tableType": "Input",
            "primaryKey": "user_id",
            "description": "Behavioral events from the Luminary Health portal — page views, form submits, searches.",
            "fields": [
              { "id": "fld_he_user_id",    "name": "user_id",     "dataType": "Text",      "isPrimaryKey": true  },
              { "id": "fld_he_event_type", "name": "event_type",  "dataType": "Text",      "isPrimaryKey": false },
              { "id": "fld_he_timestamp",  "name": "timestamp",   "dataType": "Timestamp", "isPrimaryKey": false },
              { "id": "fld_he_utm_source", "name": "utm_source",  "dataType": "Text",      "isPrimaryKey": false },
              { "id": "fld_he_lang",       "name": "lang",        "dataType": "Text",      "isPrimaryKey": false }
            ]
          },
          "tbl_appt_requests": {
            "type": "Table",
            "name": "AppointmentRequests",
            "tableType": "Input",
            "primaryKey": "user_id",
            "description": "Appointment requests submitted via the health portal, synced from CRM.",
            "fields": [
              { "id": "fld_ar_user_id",      "name": "user_id",        "dataType": "Text",      "isPrimaryKey": true  },
              { "id": "fld_ar_service_type", "name": "service_type",   "dataType": "Text",      "isPrimaryKey": false },
              { "id": "fld_ar_req_date",     "name": "requested_date", "dataType": "Timestamp", "isPrimaryKey": false },
              { "id": "fld_ar_status",       "name": "status",         "dataType": "Text",      "isPrimaryKey": false }
            ]
          },
          "tbl_high_intent": {
            "type": "Table",
            "name": "HighIntentUsers",
            "tableType": "Transform",
            "primaryKey": "user_id",
            "description": "Users who submitted a form or requested an appointment in the last 30 days.",
            "fields": [
              { "id": "fld_hi_user_id",     "name": "user_id",          "dataType": "Text",      "isPrimaryKey": true  },
              { "id": "fld_hi_signal",      "name": "intent_signal",    "dataType": "Text",      "isPrimaryKey": false },
              { "id": "fld_hi_last_action", "name": "last_action_date", "dataType": "Timestamp", "isPrimaryKey": false }
            ]
          },
          "tbl_broad_health": {
            "type": "Table",
            "name": "BroadHealthUsers",
            "tableType": "Transform",
            "primaryKey": "user_id",
            "description": "Users with 3 or more health page views in the last 30 days.",
            "fields": [
              { "id": "fld_bh_user_id",    "name": "user_id",        "dataType": "Text",    "isPrimaryKey": true  },
              { "id": "fld_bh_page_views", "name": "page_view_count","dataType": "Integer", "isPrimaryKey": false }
            ]
          },
          "tbl_spanish": {
            "type": "Table",
            "name": "SpanishSpeakers",
            "tableType": "Transform",
            "primaryKey": "user_id",
            "description": "Users with language preference set to Spanish (lang = es).",
            "fields": [
              { "id": "fld_es_user_id", "name": "user_id", "dataType": "Text", "isPrimaryKey": true  },
              { "id": "fld_es_lang",    "name": "lang",    "dataType": "Text", "isPrimaryKey": false }
            ]
          },
          "imp_health_events": {
            "type": "Import",
            "name": "HealthUserEvents Feed",
            "source": "Health Portal",
            "frequency": "Daily",
            "syncMode": "Daily"
          },
          "imp_appt": {
            "type": "Import",
            "name": "AppointmentRequests Feed",
            "source": "CRM",
            "frequency": "Daily",
            "syncMode": "Daily"
          },
          "fo_high_intent_filter": {
            "type": "Filter",
            "name": "High Intent Filter",
            "predicate": "event_type = form_submit OR appt_request within 30d"
          },
          "fo_broad_filter": {
            "type": "Filter",
            "name": "Broad Health Filter",
            "predicate": "page_view_count >= 3 within 30d"
          },
          "fo_lang_detect": {
            "type": "AlgoAI",
            "name": "Language Detect",
            "optimization": "Route",
            "promoted": true
          },
          "ua_high_intent": {
            "type": "Output",
            "name": "LMH_HighIntent_UA",
            "maxRows": 1,
            "fields": [
              { "id": "of_hi_user_id", "name": "user_id",    "sourceFieldId": "tbl_high_intent.fld_hi_user_id"    },
              { "id": "of_hi_signal",  "name": "intent_signal","sourceFieldId": "tbl_high_intent.fld_hi_signal"  }
            ]
          },
          "ua_broad": {
            "type": "Output",
            "name": "LMH_Broad_UA",
            "maxRows": 1,
            "fields": [
              { "id": "of_bh_user_id",    "name": "user_id",        "sourceFieldId": "tbl_broad_health.fld_bh_user_id"    },
              { "id": "of_bh_page_views", "name": "page_view_count","sourceFieldId": "tbl_broad_health.fld_bh_page_views" }
            ]
          },
          "ua_es": {
            "type": "Output",
            "name": "LMH_ES_UA",
            "maxRows": 1,
            "fields": [
              { "id": "of_es_user_id", "name": "user_id", "sourceFieldId": "tbl_spanish.fld_es_user_id" },
              { "id": "of_es_lang",    "name": "lang",    "sourceFieldId": "tbl_spanish.fld_es_lang"    }
            ]
          }
        },
        "connections": [
          { "from": "imp_health_events",      "to": "tbl_health_events"     },
          { "from": "imp_appt",               "to": "tbl_appt_requests"     },
          { "from": "tbl_health_events",      "to": "fo_high_intent_filter" },
          { "from": "tbl_health_events",      "to": "fo_broad_filter"       },
          { "from": "tbl_health_events",      "to": "fo_lang_detect"        },
          { "from": "tbl_appt_requests",      "to": "fo_high_intent_filter" },
          { "from": "fo_high_intent_filter",  "to": "tbl_high_intent"       },
          { "from": "fo_broad_filter",        "to": "tbl_broad_health"      },
          { "from": "fo_lang_detect",         "to": "tbl_spanish"           },
          { "from": "tbl_high_intent",        "to": "ua_high_intent"        },
          { "from": "tbl_broad_health",       "to": "ua_broad"              },
          { "from": "tbl_spanish",            "to": "ua_es"                 }
        ]
      }
